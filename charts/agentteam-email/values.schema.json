{
  "$defs": {
    "image": {
      "properties": {
        "digest": { "minLength": 1, "type": "string" },
        "pullPolicy": { "minLength": 1, "type": "string" },
        "repository": { "minLength": 1, "type": "string" },
        "tag": { "minLength": 1, "type": "string" }
      },
      "type": "object"
    },
    "keyRef": {
      "additionalProperties": false,
      "properties": {
        "key": { "minLength": 1, "type": "string" },
        "name": { "minLength": 1, "type": "string" }
      },
      "required": ["name", "key"],
      "type": "object"
    },
    "persistentService": {
      "properties": {
        "accessModes": {
          "items": { "minLength": 1, "type": "string" },
          "minItems": 1,
          "type": "array"
        },
        "existingClaim": { "type": "string" },
        "size": { "minLength": 1, "type": "string" }
      },
      "type": "object"
    },
    "valueSource": {
      "anyOf": [{ "required": ["value"] }, { "required": ["valueFrom"] }],
      "properties": {
        "value": { "type": ["string", "number", "boolean"] },
        "valueFrom": {
          "additionalProperties": false,
          "oneOf": [{ "required": ["secretKeyRef"] }, { "required": ["configMapKeyRef"] }],
          "properties": {
            "configMapKeyRef": { "$ref": "#/$defs/keyRef" },
            "secretKeyRef": { "$ref": "#/$defs/keyRef" }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "properties": {
    "admin": {
      "properties": {
        "cloudflare": {
          "properties": {
            "apiBaseUrl": { "minLength": 1, "type": "string" },
            "oauth": {
              "properties": {
                "authorizationUrl": { "$ref": "#/$defs/valueSource" },
                "clientId": { "$ref": "#/$defs/valueSource" },
                "clientSecret": { "$ref": "#/$defs/valueSource" },
                "issuer": { "$ref": "#/$defs/valueSource" },
                "revokeUrl": { "$ref": "#/$defs/valueSource" },
                "scopes": { "$ref": "#/$defs/valueSource" },
                "tokenUrl": { "$ref": "#/$defs/valueSource" },
                "userInfoUrl": { "$ref": "#/$defs/valueSource" }
              },
              "type": "object"
            },
            "r2": {
              "properties": {
                "accessKeyId": { "$ref": "#/$defs/valueSource" },
                "accountId": { "$ref": "#/$defs/valueSource" },
                "apiToken": { "$ref": "#/$defs/valueSource" },
                "bucket": { "$ref": "#/$defs/valueSource" },
                "endpoint": { "$ref": "#/$defs/valueSource" },
                "region": { "$ref": "#/$defs/valueSource" },
                "secretAccessKey": { "$ref": "#/$defs/valueSource" }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "smtp": {
          "properties": {
            "address": { "$ref": "#/$defs/valueSource" },
            "fromEmail": { "$ref": "#/$defs/valueSource" },
            "password": { "$ref": "#/$defs/valueSource" },
            "port": { "$ref": "#/$defs/valueSource" },
            "replyToEmail": { "$ref": "#/$defs/valueSource" },
            "secureTls": { "$ref": "#/$defs/valueSource" },
            "sendAsEmail": { "$ref": "#/$defs/valueSource" },
            "username": { "$ref": "#/$defs/valueSource" }
          },
          "type": "object"
        },
        "socialAuth": {
          "properties": {
            "google": {
              "properties": {
                "clientId": { "$ref": "#/$defs/valueSource" },
                "clientSecret": { "$ref": "#/$defs/valueSource" }
              },
              "type": "object"
            },
            "linkedin": {
              "properties": {
                "clientId": { "$ref": "#/$defs/valueSource" },
                "clientSecret": { "$ref": "#/$defs/valueSource" }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "stripe": {
          "properties": {
            "publishableKey": { "$ref": "#/$defs/valueSource" },
            "secretKey": { "$ref": "#/$defs/valueSource" }
          },
          "type": "object"
        },
        "trial": {
          "properties": {
            "admissionToken": { "$ref": "#/$defs/valueSource" },
            "capabilities": { "$ref": "#/$defs/valueSource" },
            "claimIntentTtlSeconds": { "$ref": "#/$defs/valueSource" },
            "dailySendLimit": { "$ref": "#/$defs/valueSource" },
            "domain": { "$ref": "#/$defs/valueSource" },
            "enabled": { "$ref": "#/$defs/valueSource" },
            "mailboxLifetimeSeconds": { "$ref": "#/$defs/valueSource" },
            "mailboxLocalPrefix": { "$ref": "#/$defs/valueSource" },
            "maxActive": { "$ref": "#/$defs/valueSource" },
            "organizationId": { "$ref": "#/$defs/valueSource" },
            "totalSendLimit": { "$ref": "#/$defs/valueSource" }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "affinity": { "type": "object" },
    "bundledConfig": {
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "type": "object"
    },
    "containerSecurityContext": { "type": "object" },
    "controlApi": {
      "properties": {
        "controlToWebToken": { "$ref": "#/$defs/valueSource" }
      },
      "type": "object"
    },
    "extraEnv": { "type": "object" },
    "extraLabels": {
      "properties": {
        "mailControlService": { "additionalProperties": { "type": "string" }, "type": "object" },
        "namespace": { "additionalProperties": { "type": "string" }, "type": "object" },
        "webServer": { "additionalProperties": { "type": "string" }, "type": "object" },
        "wildduck": { "additionalProperties": { "type": "string" }, "type": "object" }
      },
      "type": "object"
    },
    "extraVolumeMounts": { "type": "object" },
    "extraVolumes": { "type": "object" },
    "fullnameOverride": { "type": "string" },
    "images": {
      "properties": {
        "haraka": { "$ref": "#/$defs/image" },
        "mailControlService": { "$ref": "#/$defs/image" },
        "mongodb": { "$ref": "#/$defs/image" },
        "redis": { "$ref": "#/$defs/image" },
        "rspamd": { "$ref": "#/$defs/image" },
        "webServer": { "$ref": "#/$defs/image" },
        "wildduck": { "$ref": "#/$defs/image" },
        "zonemta": { "$ref": "#/$defs/image" }
      },
      "type": "object"
    },
    "ingress": { "type": "object" },
    "mailControlService": { "type": "object" },
    "mailRuntime": {
      "properties": {
        "feedbackMailboxPassword": { "$ref": "#/$defs/valueSource" },
        "loopSecret": { "$ref": "#/$defs/valueSource" },
        "zonemtaRelayPassword": { "$ref": "#/$defs/valueSource" }
      },
      "type": "object"
    },
    "mongodb": {
      "properties": {
        "maxIncomingConnections": { "minimum": 1, "type": "integer" },
        "replicaSetName": { "minLength": 1, "type": "string" },
        "terminationGracePeriodSeconds": { "minimum": 1, "type": "integer" }
      },
      "type": "object"
    },
    "nameOverride": { "type": "string" },
    "names": { "type": "object" },
    "namespace": {
      "properties": {
        "create": { "type": "boolean" },
        "name": { "minLength": 1, "type": "string" }
      },
      "type": "object"
    },
    "nodeSelector": { "type": "object" },
    "persistence": {
      "properties": {
        "enabled": { "type": "boolean" },
        "harakaQueue": { "$ref": "#/$defs/persistentService" },
        "mongodb": { "$ref": "#/$defs/persistentService" },
        "redis": { "$ref": "#/$defs/persistentService" },
        "rspamd": { "$ref": "#/$defs/persistentService" },
        "storageClassName": { "type": "string" }
      },
      "type": "object"
    },
    "podSecurityContext": { "type": "object" },
    "publicHostname": { "minLength": 1, "type": "string" },
    "resources": { "type": "object" },
    "service": { "type": "object" },
    "tolerations": { "type": "array" },
    "webServer": {
      "properties": {
        "authSecret": { "$ref": "#/$defs/valueSource" },
        "databaseMaxPoolSize": { "minimum": 1, "type": "integer" },
        "encryptionKey": { "$ref": "#/$defs/valueSource" },
        "tmpDir": { "$ref": "#/$defs/valueSource" }
      },
      "type": "object"
    },
    "wildduck": {
      "properties": {
        "accessControlSecret": { "$ref": "#/$defs/valueSource" },
        "adminAccessToken": { "$ref": "#/$defs/valueSource" }
      },
      "type": "object"
    }
  },
  "type": "object"
}
