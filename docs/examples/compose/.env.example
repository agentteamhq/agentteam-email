# Docker Compose self-hosting environment example.
# Copy these values into the environment used by compose.yaml or compose.no-db.yaml.

# Runtime and release selection
AGENTTEAM_EMAIL_VERSION=latest
AGENTTEAM_EMAIL_PULL_POLICY=always
AGENTTEAM_EMAIL_UID=1000
AGENTTEAM_EMAIL_GID=1000

# Public frontend
PUBLIC_HOSTNAME=http://localhost:23100
BETTER_AUTH_SECRET=example-better-auth-secret-change-me
ENCRYPT_SECRET_KEY=ZGV2LW9ubHktY29va2llLWVuY3J5cHRpb24ta2V5ISE

# External database URLs required by compose.no-db.yaml.
# compose.yaml defaults these to the bundled MongoDB and Redis services.
# AGENTTEAM_EMAIL_APP_MONGODB_URI=mongodb://user:password@mongodb.example:27017/agentteam_email?authSource=admin&tls=true
# AGENTTEAM_EMAIL_WILDDUCK_MONGODB_URI=mongodb://user:password@mongodb.example:27017/wildduck?authSource=admin&tls=true
# AGENTTEAM_EMAIL_CONTROL_MONGODB_URI=mongodb://user:password@mongodb.example:27017/agent_mail_control?authSource=admin&tls=true
# AGENTTEAM_EMAIL_REDIS_URL=rediss://:password@redis.example:6379/3
AGENTTEAM_EMAIL_APP_MONGODB_URI=mongodb://user:password@mongodb.example:27017/agentteam_email?authSource=admin
AGENTTEAM_EMAIL_WILDDUCK_MONGODB_URI=mongodb://user:password@mongodb.example:27017/wildduck?authSource=admin
AGENTTEAM_EMAIL_CONTROL_MONGODB_URI=mongodb://user:password@mongodb.example:27017/agent_mail_control?authSource=admin
AGENTTEAM_EMAIL_REDIS_URL=rediss://:password@redis.example:6379/3

# Control API
AGENT_MAIL_CONTROL_API_TOKEN=example-control-api-token-change-me

# WildDuck service credentials
AGENT_MAIL_WILDDUCK_ADMIN_ACCESS_TOKEN=example-wildduck-admin-token-change-me
AGENT_MAIL_WILDDUCK_ACCESS_CONTROL_SECRET=example-wildduck-access-control-secret-change-me

# Internal mail runtime secrets
AGENT_MAIL_LOOP_SECRET=example-mail-loop-secret-change-me
AGENT_MAIL_ZONEMTA_RELAY_PASSWORD=example-zonemta-relay-password-change-me
AGENT_MAIL_FEEDBACK_MAILBOX_PASSWORD=example-feedback-mailbox-password-change-me

# R2/S3-compatible archive storage
AGENT_MAIL_R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
AGENT_MAIL_R2_REGION=auto
AGENT_MAIL_R2_BUCKET=agent-mail-archive
AGENT_MAIL_R2_ACCESS_KEY_ID=example-r2-access-key-id
AGENT_MAIL_R2_SECRET_ACCESS_KEY=example-r2-secret-access-key

# Cloudflare API and Worker provisioning
AGENT_MAIL_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
AGENT_MAIL_CLOUDFLARE_ACCOUNT_ID=example-cloudflare-account-id
AGENT_MAIL_CLOUDFLARE_API_TOKEN=example-cloudflare-api-token
AGENT_MAIL_CLOUDFLARE_WORKER_SCRIPT_NAME=agent-mail-ingress
AGENT_MAIL_CLOUDFLARE_WORKER_ARCHIVE_BUCKET=agent-mail-archive

# Worker fast-path ingest; route this full public URL to the fast-path gate
AGENT_MAIL_CF_TUNNEL_LISTEN_URL=http://0.0.0.0:8080
AGENT_MAIL_CF_TUNNEL_EXTERNAL_URL=https://agent-mail-ingress.example.com/agent-mail/ingest/v1
AGENT_MAIL_CF_TUNNEL_HMAC_SECRET=example-fastpath-hmac-secret-change-me

# Optional Tailscale values used by self-host examples
TAILSCALE_TAILNET_DNS_NAME=example.ts.net
AGENT_MAIL_TAILSCALE_AUTH_KEY=

# Outbound provider. Supported values are cloudflare and ses.
AGENT_MAIL_OUTBOUND_PROVIDER=cloudflare

# Optional SES provider credentials when AGENT_MAIL_OUTBOUND_PROVIDER=ses
AGENT_MAIL_AWS_REGION=
AGENT_MAIL_AWS_ACCESS_KEY_ID=
AGENT_MAIL_AWS_SECRET_ACCESS_KEY=

# Optional local frontend port override
FRONTEND_PORT=23100
