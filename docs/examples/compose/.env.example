# Docker Compose self-hosting environment example.
# Copy this file to .env, set every uncommented value, and leave commented
# defaults unset unless you are intentionally overriding the default topology.

# Required public admin web app.
AT_EMAIL_ADMIN_PUBLIC_HOSTNAME=http://localhost:23100
AT_EMAIL_ADMIN_BETTER_AUTH_SECRET=example-better-auth-secret-change-me
AT_EMAIL_ADMIN_ENCRYPT_SECRET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Optional runtime and release defaults.
# AT_EMAIL_ADMIN_VERSION=latest
# AT_EMAIL_ADMIN_PULL_POLICY=always
# First-party app containers only; bundled services use image-defined users.
# AT_EMAIL_ADMIN_UID=1000
# AT_EMAIL_ADMIN_GID=1000
# AT_EMAIL_ADMIN_FRONTEND_PORT=23100
# AT_EMAIL_ADMIN_DATABASE_MAX_POOL_SIZE=8
# AT_EMAIL_ADMIN_TMP_DIR=/tmp/agentteam-email

# Optional database URL overrides.
# compose.yaml defaults to the bundled MongoDB and Redis services.
# AT_EMAIL_ADMIN_APP_MONGODB_URI=mongodb://mongodb:27017/agentteam_email?replicaSet=rs0
# AT_EMAIL_ADMIN_WILDDUCK_MONGODB_URI=mongodb://mongodb:27017/wildduck?replicaSet=rs0&maxPoolSize=4&minPoolSize=0&maxIdleTimeMS=60000
# AT_EMAIL_ADMIN_CONTROL_MONGODB_URI=mongodb://mongodb:27017/agent_mail_control?replicaSet=rs0&maxPoolSize=4&minPoolSize=0&maxIdleTimeMS=60000
# AT_EMAIL_ADMIN_REDIS_URL=redis://redis:6379/3

# Required internal service credentials.
AT_EMAIL_ADMIN_CONTROL_TO_WEB_API_TOKEN=example-control-to-web-api-token-change-me
AT_EMAIL_ADMIN_WILDDUCK_ADMIN_ACCESS_TOKEN=example-wildduck-admin-token-change-me
AT_EMAIL_ADMIN_WILDDUCK_ACCESS_CONTROL_SECRET=example-wildduck-access-control-secret-change-me
AT_EMAIL_ADMIN_MAIL_LOOP_SECRET=example-mail-loop-secret-change-me
AT_EMAIL_ADMIN_ZONEMTA_RELAY_PASSWORD=example-zonemta-relay-password-change-me
AT_EMAIL_ADMIN_FEEDBACK_MAILBOX_PASSWORD=example-feedback-mailbox-password-change-me

# Advanced internal topology overrides. Leave unset for the default Compose network.
# AT_EMAIL_ADMIN_WILDDUCK_API_BASE_URL=http://wildduck:8080
# AT_EMAIL_ADMIN_WILDDUCK_IMAP_ADDRESS=wildduck:10143
# AT_EMAIL_ADMIN_HARAKA_SMTP_ADDRESS=haraka:10025
# AT_EMAIL_ADMIN_ZONEMTA_DSN_ADDRESS=zonemta:2526
# AT_EMAIL_ADMIN_CONTROL_TO_WEB_API_BASE_URL=http://atemail-web-server:4321

# Required Cloudflare admin OAuth app.
# Users connect their domains from the web UI with this OAuth app. Configure
# the Cloudflare OAuth client for Authorization Code + PKCE with token endpoint
# auth method `none`.
AT_EMAIL_ADMIN_CF_OAUTH_CLIENT_ID=example-cloudflare-oauth-client-id

# Advanced Cloudflare OAuth/API overrides. Leave unset for normal Cloudflare.
# AT_EMAIL_ADMIN_CF_API_BASE_URL=https://api.cloudflare.com/client/v4
# AT_EMAIL_ADMIN_CF_OAUTH_AUTHORIZATION_URL=
# AT_EMAIL_ADMIN_CF_OAUTH_TOKEN_URL=
# AT_EMAIL_ADMIN_CF_OAUTH_USERINFO_URL=
# AT_EMAIL_ADMIN_CF_OAUTH_REVOKE_URL=
# AT_EMAIL_ADMIN_CF_OAUTH_ISSUER=

# Required Cloudflare R2 archive bucket owned by the admin instance.
AT_EMAIL_ADMIN_R2_ACCOUNT_ID=example-cloudflare-account-id
AT_EMAIL_ADMIN_R2_API_TOKEN=example-r2-api-token
AT_EMAIL_ADMIN_R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
# AT_EMAIL_ADMIN_R2_REGION=auto
AT_EMAIL_ADMIN_R2_BUCKET=agent-mail-archive
AT_EMAIL_ADMIN_R2_ACCESS_KEY_ID=example-r2-access-key-id
AT_EMAIL_ADMIN_R2_SECRET_ACCESS_KEY=example-r2-secret-access-key

# Optional agent trial policy. Disabled unless AT_EMAIL_ADMIN_TRIAL_ENABLED=true.
# AT_EMAIL_ADMIN_TRIAL_ENABLED=false
# AT_EMAIL_ADMIN_TRIAL_ORGANIZATION_ID=
# AT_EMAIL_ADMIN_TRIAL_DOMAIN=
# AT_EMAIL_ADMIN_TRIAL_ADMISSION_TOKEN=
# AT_EMAIL_ADMIN_TRIAL_CAPABILITIES=email.status,email.message.list,email.message.read,email.message.search,email.message.create_draft,email.message.send,email.message.reply
# AT_EMAIL_ADMIN_TRIAL_CLAIM_INTENT_TTL_SECONDS=86400
# AT_EMAIL_ADMIN_TRIAL_DAILY_SEND_LIMIT=10
# AT_EMAIL_ADMIN_TRIAL_MAILBOX_LIFETIME_SECONDS=604800
# AT_EMAIL_ADMIN_TRIAL_MAILBOX_LOCAL_PREFIX=trial
# AT_EMAIL_ADMIN_TRIAL_MAX_ACTIVE=25
# AT_EMAIL_ADMIN_TRIAL_TOTAL_SEND_LIMIT=50

# Optional admin sign-in providers. Leave commented unless the provider is enabled.
# AT_EMAIL_ADMIN_GOOGLE_CLIENT_ID=
# AT_EMAIL_ADMIN_GOOGLE_CLIENT_SECRET=
# AT_EMAIL_ADMIN_LINKEDIN_CLIENT_ID=
# AT_EMAIL_ADMIN_LINKEDIN_CLIENT_SECRET=

# Optional Stripe integration.
# AT_EMAIL_ADMIN_STRIPE_PUBLISHABLE_KEY=
# AT_EMAIL_ADMIN_STRIPE_SECRET_KEY=

# Optional admin transactional SMTP. This is not used for user-domain mail.
# AT_EMAIL_ADMIN_SMTP_ADDRESS=
# AT_EMAIL_ADMIN_SMTP_PORT=1025
# AT_EMAIL_ADMIN_SMTP_SECURE_TLS=false
# AT_EMAIL_ADMIN_SMTP_USERNAME=
# AT_EMAIL_ADMIN_SMTP_PASSWORD=
# AT_EMAIL_ADMIN_SMTP_FROM_EMAIL=
# AT_EMAIL_ADMIN_SMTP_REPLY_TO_EMAIL=
# AT_EMAIL_ADMIN_SMTP_SEND_AS_EMAIL=
