{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "apiReport": {
    "enabled": false,
    "includeForgottenExports": true
  },
  "compiler": {
    "tsconfigFilePath": "./tsconfig.json"
  },
  "docModel": {
    "enabled": false
  },
  "dtsRollup": {
    "enabled": false,
    "untrimmedFilePath": "./dist/src/index.d.ts"
  },
  "mainEntryPointFilePath": "./dist/src/index.d.ts",
  "messages": {
    "compilerMessageReporting": { "default": { "logLevel": "error" } },
    "extractorMessageReporting": {
      "ae-forgotten-export": {
        "logLevel": "error"
      },
      "ae-missing-release-tag": {
        "logLevel": "none"
      },
      "default": { "logLevel": "error" }
    },
    "tsdocMessageReporting": {
      "default": { "logLevel": "warning" },
      "tsdoc-at-sign-in-word": {
        "logLevel": "none"
      },
      "tsdoc-characters-after-block-tag": {
        "logLevel": "none"
      },
      "tsdoc-code-span-empty": {
        "logLevel": "none"
      },
      "tsdoc-code-span-missing-delimiter": {
        "logLevel": "none"
      },
      "tsdoc-escape-greater-than": {
        "logLevel": "none"
      },
      "tsdoc-escape-right-brace": {
        "logLevel": "none"
      },
      "tsdoc-malformed-html-name": {
        "logLevel": "none"
      },
      "tsdoc-malformed-inline-tag": {
        "logLevel": "none"
      },
      "tsdoc-malformed-tag-name": {
        "logLevel": "none"
      },
      "tsdoc-missing-deprecation-message": {
        "logLevel": "none"
      },
      "tsdoc-undefined-tag": {
        "logLevel": "none"
      }
    }
  },
  "tsdocMetadata": {
    "enabled": false,
    "tsdocMetadataFilePath": "./dist/tsdoc-metadata.json"
  }
}
