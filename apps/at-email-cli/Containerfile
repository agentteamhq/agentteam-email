FROM docker.io/library/golang:1.26.4 AS test

WORKDIR /src

COPY go.mod ./
COPY SKILL.md skill.go ./
COPY cmd ./cmd
COPY internal ./internal

RUN go test ./...

FROM docker.io/library/golang:1.26.4 AS build

WORKDIR /src

ARG TARGETOS=linux
ARG TARGETARCH=amd64
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG VERSION=0.1.0-dev

COPY go.mod ./
COPY SKILL.md skill.go ./
COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -trimpath -ldflags="-s -w -X at-email-cli/internal/atemail.Version=${VERSION} -X at-email-cli/internal/atemail.Commit=${VCS_REF} -X at-email-cli/internal/atemail.Date=${BUILD_DATE}" -o /out/at-email ./cmd/at-email

FROM docker.io/library/alpine:3.23.4

ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG VERSION=0.1.0-dev

LABEL "org.opencontainers.image.title"="AgentTeam Email CLI" \
  "org.opencontainers.image.description"="Portable at-email mailbox CLI" \
  "org.opencontainers.image.authors"="AgentTeam" \
  "org.opencontainers.image.url"="https://www.agentteam.email" \
  "org.opencontainers.image.source"="https://github.com/agentteamhq/agentteam-email" \
  "org.opencontainers.image.documentation"="https://agentteamemail.mintlify.com" \
  "org.opencontainers.image.vendor"="AgentTeam" \
  "org.opencontainers.image.licenses"="MIT" \
  "org.opencontainers.image.ref.name"="atemail-cli" \
  "org.opencontainers.image.created"="${BUILD_DATE}" \
  "org.opencontainers.image.revision"="${VCS_REF}" \
  "org.opencontainers.image.version"="${VERSION}"

RUN apk add --no-cache ca-certificates && adduser -D -H -u 65532 appuser

USER appuser

COPY --from=build /out/at-email /usr/local/bin/at-email

ENTRYPOINT ["/usr/local/bin/at-email"]
