{
  "name": "@main/web-server",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "audit:runtime-imports": "node ./scripts/audit-runtime-imports.mjs",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false --noCheck --outDir dist",
    "clean": "rimraf --glob dist .turbo node_modules/.cache node_modules/.vite* .eslintcache *.tsbuildinfo",
    "db:seed": "node scripts/seed.mjs",
    "dev": "vite build --watch",
    "format": "pnpm run lint --fix && pnpm exec prettier --write ./src",
    "lint": "eslint --quiet ${ESLINT_CACHE_FLAG:---cache} --concurrency ${ESLINT_CONCURRENCY:-auto} ./src",
    "preview": "node --env-file=../../.env dist/index.mjs",
    "test:integration": "pnpm run audit:runtime-imports",
    "typecheck": "tsc --noEmit",
    "typecheck:debug": "tsc --noEmit --listFiles"
  },
