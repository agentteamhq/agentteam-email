FROM docker.io/library/golang:1.26.4 AS build

WORKDIR /src

ARG TARGETOS=linux
ARG TARGETARCH=amd64

COPY go.mod ./
COPY go.sum ./
COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -trimpath -ldflags='-s -w' -o /out/agent-mail-control-service ./cmd/agent-mail-control-service

FROM docker.io/library/alpine:3.23.4

ARG BUILD_DATE
ARG VCS_REF
ARG VERSION

LABEL "org.opencontainers.image.title"="AgentTeam Email Mail Control Service" \
  "org.opencontainers.image.description"="Internal mail control service for AgentTeam Email self-hosted deployments" \
  "org.opencontainers.image.authors"="AgentTeam" \
  "org.opencontainers.image.url"="https://www.agentteam.email" \
  "org.opencontainers.image.source"="https://github.com/agentteamhq/agentteam-email" \
  "org.opencontainers.image.documentation"="https://agentteamemail.mintlify.com" \
  "org.opencontainers.image.vendor"="AgentTeam" \
  "org.opencontainers.image.licenses"="MIT" \
  "org.opencontainers.image.ref.name"="atemail-mail-control-service" \
  "org.opencontainers.image.created"="${BUILD_DATE}" \
  "org.opencontainers.image.revision"="${VCS_REF}" \
  "org.opencontainers.image.version"="${VERSION}"

RUN adduser -D -H -u 65532 appuser

USER appuser

COPY --from=build /out/agent-mail-control-service /usr/local/bin/agent-mail-control-service

ENTRYPOINT ["/usr/local/bin/agent-mail-control-service"]
