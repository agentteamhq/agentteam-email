# Local development environment example.
# This file is for repo-local app development. Docker Compose self-hosting uses
# docs/examples/compose/.env.example instead.

# Kebab-case checkout/worktree identity. Keep `main` in the main checkout.
WT=main

# Container engine used by repo-owned local runtime, image build, and kind E2E
# tasks. Set to `docker` to use Docker-compatible CLI commands instead.
CONTAINER_ENGINE=podman

# PODMAN_SOCK must come from the invoking shell/profile.
# Do not define it in repo-local .env files.

# Web settings
PUBLIC_HOSTNAME=http://localhost:4321
NODE_ENV=development
FRONTEND_PORT=4321

# Debug logging
PUBLIC_DEBUG=true
DEBUG=app:*,react-compiler,db,ai-context,test
DEBUG_HIDE_DATE=1

# Database
# `mise run db:start` starts/reuses a local MongoDB container for this URI.
MONGODB_URI=mongodb://localhost:27017/agentteam_email_main
MONGODB_DATABASE=agentteam_email_main
# Compatibility for tools that still read DATABASE_URL.
DATABASE_URL=mongodb://localhost:27017/agentteam_email_main

# Auth
BETTER_AUTH_SECRET=asecurepasswordasecurepasswordasecurepasswordasecurepassword
# 32 random bytes encoded as base64url. Generate per environment; required in production.
ENCRYPT_SECRET_KEY=asecurepasswordasecurepasswordasecurepasswordasecurepassword
# Testcontainers E2E harnesses set these per run when they need a verified
# test principal without exercising signup/email verification. Do not enable
# them for ordinary local development, staging, or production.
# E2E_TEST_SUPPORT_ENABLED=false
# E2E_TEST_SUPPORT_TOKEN=

# OAuth
PUBLIC_GOOGLE_CLIENT_ID=client_id_test_
GOOGLE_CLIENT_SECRET=client_secret_test_
PUBLIC_LINKEDIN_CLIENT_ID=client_id_test_
LINKEDIN_CLIENT_SECRET=client_secret_test_

# Cloudflare OAuth local development overrides are optional.
# CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
# CLOUDFLARE_OAUTH_AUTHORIZATION_URL=
# CLOUDFLARE_OAUTH_CLIENT_ID=
# CLOUDFLARE_OAUTH_CLIENT_SECRET=
# CLOUDFLARE_OAUTH_ISSUER=
# CLOUDFLARE_OAUTH_REVOKE_URL=
# CLOUDFLARE_OAUTH_SCOPES=
# CLOUDFLARE_OAUTH_TOKEN_URL=
# CLOUDFLARE_OAUTH_USERINFO_URL=

# Stripe local development overrides are optional.
# STRIPE_PUBLISHABLE_KEY=pk_test_
# STRIPE_SECRET_KEY=sk_test_

# SMTP / nodemailer
SMTP_SEND_AS_EMAIL=noreply@app.internal
SMTP_REPLY_TO_EMAIL=noreply@app.internal
SMTP_ADDRESS=127.0.0.1
SMTP_FROM_EMAIL='"App Notifier" <noreply@app.internal>'
SMTP_PORT=1025
SMTP_USERNAME=app
SMTP_PASSWORD=app
SMTP_SECURE_TLS=false

TMP_DIR=tmp

# Build configuration used by Vite packages and apps/web-server.
BUILD_MINIFY=true
BUILD_SOURCEMAPS=true
BUILD_REACT_PROFILER=false
BUILD_ANALYZE_BUNDLE=false

# Local production server preview port.
PORT=4321
