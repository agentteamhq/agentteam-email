# Local development environment example.
# This file is for repo-local app development. Docker Compose self-hosting uses
# docs/examples/compose/.env.example instead.

# Kebab-case checkout/worktree identity. Keep `main` in the main checkout.
WT=main

# PODMAN_SOCK must come from the invoking shell/profile.
# Do not define it in repo-local .env files.

# Web settings
PUBLIC_HOSTNAME=http://localhost:4321
NODE_ENV=development
FRONTEND_PORT=4321
# Set DEV_HTTPS=true to run the frontend dev server over HTTPS. DEV_TLS_CERT
# and DEV_TLS_KEY should come from your local shell/profile, not this file.
# DEV_HTTPS=false

# Debug logging
PUBLIC_DEBUG=true
DEBUG=app:*,react-compiler,db,ai-context,test
DEBUG_HIDE_DATE=1

# Database
# `mise run dev:start` starts the local development support stack for this URI.
MONGODB_URI=mongodb://127.0.0.1:27017/agentteam_email_main?directConnection=true
MONGODB_DATABASE=agentteam_email_main
# Compatibility for tools that still read DATABASE_URL.
DATABASE_URL=mongodb://127.0.0.1:27017/agentteam_email_main?directConnection=true

# Auth
BETTER_AUTH_SECRET=asecurepasswordasecurepasswordasecurepasswordasecurepassword
# 32 random bytes encoded as base64url. Generate per environment; required in production.
ENCRYPT_SECRET_KEY=asecurepasswordasecurepasswordasecurepasswordasecurepassword
# Testcontainers E2E harnesses set these per run when they need a verified
# test principal without exercising signup/email verification. Do not enable
# them for ordinary local development, staging, or production.
# E2E_TEST_SUPPORT_ENABLED=false
# E2E_TEST_SUPPORT_TOKEN=

# OAuth
PUBLIC_GOOGLE_CLIENT_ID=client_id_test_
GOOGLE_CLIENT_SECRET=client_secret_test_
PUBLIC_LINKEDIN_CLIENT_ID=client_id_test_
LINKEDIN_CLIENT_SECRET=client_secret_test_

# Cloudflare OAuth local development overrides are optional.
# CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
# CLOUDFLARE_OAUTH_AUTHORIZATION_URL=
# CLOUDFLARE_OAUTH_CLIENT_ID=
# CLOUDFLARE_OAUTH_ISSUER=
# CLOUDFLARE_OAUTH_REVOKE_URL=
# CLOUDFLARE_OAUTH_TOKEN_URL=
# CLOUDFLARE_OAUTH_USERINFO_URL=

# Agent Mail local development runtime. `mise run dev:start` starts the
# containerized support services, and `mise run dev:mail-control` runs the Mail
# Control Service from source against these endpoints.
AT_EMAIL_ADMIN_CONTROL_API_BASE_URL=http://127.0.0.1:8081
AT_EMAIL_ADMIN_CONTROL_TO_WEB_API_BASE_URL=http://127.0.0.1:4321
AT_EMAIL_ADMIN_CONTROL_TO_WEB_API_TOKEN=local-dev-control-to-web-token
AT_EMAIL_ADMIN_WILDDUCK_API_BASE_URL=http://127.0.0.1:8080
AT_EMAIL_ADMIN_WILDDUCK_IMAP_ADDRESS=127.0.0.1:10143
AT_EMAIL_ADMIN_WILDDUCK_MONGODB_URI=mongodb://127.0.0.1:27017/wildduck?directConnection=true
AT_EMAIL_ADMIN_WILDDUCK_ADMIN_ACCESS_TOKEN=local-dev-wildduck-admin-token
AT_EMAIL_ADMIN_WILDDUCK_ACCESS_CONTROL_SECRET=local-dev-wildduck-access-control-secret
AT_EMAIL_ADMIN_CONTROL_MONGODB_URI=mongodb://127.0.0.1:27017/agent_mail_control?directConnection=true
AT_EMAIL_ADMIN_HARAKA_SMTP_ADDRESS=127.0.0.1:10025
AT_EMAIL_ADMIN_ZONEMTA_DSN_ADDRESS=127.0.0.1:2526
AT_EMAIL_ADMIN_ZONEMTA_RELAY_PASSWORD=local-dev-zonemta-relay-password
AT_EMAIL_ADMIN_FEEDBACK_MAILBOX_PASSWORD=local-dev-feedback-mailbox-password
AT_EMAIL_ADMIN_MAIL_LOOP_SECRET=local-dev-mail-loop-secret
AT_EMAIL_ADMIN_R2_ACCOUNT_ID=local-dev-r2-account
AT_EMAIL_ADMIN_R2_API_TOKEN=local-dev-r2-api-token
AT_EMAIL_ADMIN_R2_ENDPOINT=http://127.0.0.1:9000
AT_EMAIL_ADMIN_R2_REGION=us-east-1
AT_EMAIL_ADMIN_R2_BUCKET=agent-mail-dev-archive
AT_EMAIL_ADMIN_R2_ACCESS_KEY_ID=local-dev-r2-access-key
AT_EMAIL_ADMIN_R2_SECRET_ACCESS_KEY=local-dev-r2-secret-key

# Local development support service ports. Change these per worktree when two
# dev stacks need to run at the same time on one host.
AT_EMAIL_ADMIN_DEV_MONGO_PORT=27017
AT_EMAIL_ADMIN_DEV_REDIS_PORT=6379
AT_EMAIL_ADMIN_DEV_MAILPIT_SMTP_PORT=1025
AT_EMAIL_ADMIN_DEV_MAILPIT_HTTP_PORT=8025
AT_EMAIL_ADMIN_DEV_MINIO_PORT=9000
AT_EMAIL_ADMIN_DEV_MINIO_CONSOLE_PORT=9001
AT_EMAIL_ADMIN_DEV_RSPAMD_PORT=11333
AT_EMAIL_ADMIN_DEV_WILDDUCK_API_PORT=8080
AT_EMAIL_ADMIN_DEV_WILDDUCK_IMAP_PORT=10143
AT_EMAIL_ADMIN_DEV_HARAKA_SMTP_PORT=10025
AT_EMAIL_ADMIN_DEV_ZONEMTA_DSN_PORT=2526

# Stripe local development overrides are optional.
# STRIPE_PUBLISHABLE_KEY=pk_test_
# STRIPE_SECRET_KEY=sk_test_

# SMTP / nodemailer
SMTP_SEND_AS_EMAIL=noreply@app.internal
SMTP_REPLY_TO_EMAIL=noreply@app.internal
SMTP_ADDRESS=127.0.0.1
SMTP_FROM_EMAIL='"App Notifier" <noreply@app.internal>'
SMTP_PORT=1025
SMTP_USERNAME=app
SMTP_PASSWORD=app
SMTP_SECURE_TLS=false

TMP_DIR=tmp

# Build configuration used by Vite packages and apps/web-server.
BUILD_MINIFY=true
BUILD_SOURCEMAPS=true
BUILD_REACT_PROFILER=false
BUILD_ANALYZE_BUNDLE=false

# Local production server preview port.
PORT=4321
