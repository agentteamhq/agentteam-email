{
  "name": "agentteam-email",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source email service for AI agents.",
  "keywords": [
    "agents",
    "email",
    "mail",
    "self-hosted",
    "wildduck",
    "cloudflare"
  ],
  "homepage": "https://www.agentteam.email",
  "bugs": {
    "url": "https://github.com/agentteamhq/agentteam-email/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentteamhq/agentteam-email.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "build": "turbo run build",
    "check-outdated-deps": "pnpm exec taze major -r -l",
    "clean": "rimraf --glob {.,packages/*,apps/*,test-containers/*}/{build,dist,.turbo,.cache,.tanstack,.gocache,.playwright-cli,.vitest,node_modules/.cache,node_modules/.vite*,.eslintcache,*.tsbuildinfo}",
    "dev": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --filter=@main/backend --filter=@main/frontend",
    "dev:all": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev",
    "dist": "./apps/web-server/deploy-local.sh deploy",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "lint:inspect": "pnpm exec eslint --inspect-config",
    "open": "bash -lc 'set -a; [ ! -f .env ] || . ./.env; set +a; : \"${PUBLIC_HOSTNAME:?PUBLIC_HOSTNAME is required}\"; open \"$PUBLIC_HOSTNAME\"'",
    "playwright-cli": "./node_modules/.bin/playwright-cli",
    "pnpm:reset": "rimraf --glob {.,packages/*,apps/*,test-containers/*}/{pnpm-lock.yaml,node_modules,.pnpm}",
    "preview": "turbo run preview --filter=@main/web-server",
    "test": "turbo run test --filter=!@main/auth-e2e --filter=!@main/cloudflare-oauth-e2e --filter=!@main/full-stack-e2e --filter=!@main/kind-e2e --filter=!@main/paperclip-plugin-e2e",
    "test:integration": "turbo run test && turbo run test:integration",
    "turbo": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@elysiajs/openapi": "catalog:",
    "@eslint/js": "9.39.4",
    "@microsoft/api-extractor": "7.58.7",
    "@playwright/cli": "catalog:",
    "@pnpm/lockfile.types": "1002.1.1",
    "@pnpm/logger": "1001.0.1",
    "@pnpm/pnpmfile": "1002.1.13",
    "@rolldown/plugin-babel": "catalog:",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tanstack/eslint-config": "0.3.4",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@types/debug": "4.1.13",
    "@types/estree": "1.0.9",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "8.59.4",
    "@typescript/typescript6": "catalog:",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/eslint-plugin": "1.6.18",
    "babel-plugin-react-compiler": "catalog:",
    "commander": "14.0.3",
    "debug": "catalog:",
    "elysia": "catalog:",
    "eslint": "9.39.4",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-perf": "3.3.3",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "62.0.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "mongodb-connection-string-url": "catalog:",
    "openapi-typescript": "catalog:",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "catalog:",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "prettier-plugin-classnames": "0.10.1",
    "prettier-plugin-merge": "0.10.1",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rimraf": "6.1.3",
    "tailwindcss": "catalog:",
    "taze": "19.14.1",
    "turbo": "2.9.14",
    "typescript": "npm:@typescript/typescript6@6.0.1",
    "typescript-7": "npm:typescript@7.0.1-rc",
    "typescript-eslint": "8.59.4",
    "vite": "catalog:",
    "vitest": "4.1.7",
    "ws": "8.21.0",
    "yaml": "catalog:"
  },
  "peerDependencies": {
    "rollup": "*"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}
