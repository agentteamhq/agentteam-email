{
  "name": "@main/frontend",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/server/src/index.d.ts",
        "import": "./dist/server/index.mjs"
      },
      "default": "./dist/server/index.mjs"
    }
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "browserslist": [
    "defaults and fully supports es6-module, not op_mini all"
  ],
  "scripts": {
    "build": "NODE_ENV=production vite build && NODE_ENV=production vite build --config vite.node-entry.config.ts && tsc --project tsconfig.build.json --emitDeclarationOnly --declaration --declarationMap --noEmit false --noCheck --outDir dist/server",
    "clean": "rimraf --glob dist .turbo node_modules/.cache node_modules/.vite* .eslintcache *.tsbuildinfo",
    "dev": "node --env-file-if-exists=../../.env ./node_modules/vite/bin/vite.js dev",
    "format": "pnpm run lint --fix && prettier --write ./src/**/*.{ts,tsx,css}",
    "lint": "eslint --quiet ${ESLINT_CACHE_FLAG:---cache} --concurrency ${ESLINT_CONCURRENCY:-auto} --config ./eslint.config.mjs ./src",
    "preview": "NODE_ENV=production node --env-file=../../.env dist/server/index.mjs",
    "storybook": "storybook dev -p 6007 --host 0.0.0.0 --no-version-updates",
    "storybook:build": "storybook build",
    "storybook:screenshots": "node ./scripts/storybook-screenshots.mjs",
    "storybook:test": "vitest run --config vitest.storybook.config.ts",
    "storybook:test:watch": "vitest --config vitest.storybook.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:debug": "tsc --noEmit --listFiles"
  },
