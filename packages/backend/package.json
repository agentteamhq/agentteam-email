{
  "name": "@main/backend",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    },
    "./vars.public": {
      "import": {
        "types": "./dist/src/vars.public.d.ts",
        "import": "./dist/vars.public.mjs"
      },
      "default": "./dist/vars.public.mjs"
    },
    "./vars.build": {
      "import": {
        "types": "./dist/src/vars.build.d.ts",
        "import": "./dist/vars.build.mjs"
      },
      "default": "./dist/vars.build.mjs"
    },
    "./server-only": {
      "import": {
        "types": "./dist/src/server-only.d.ts",
        "import": "./dist/server-only.mjs"
      },
      "default": "./dist/server-only.mjs"
    },
    "./routes/signin": {
      "import": {
        "types": "./dist/src/routes/signin.d.ts",
        "import": "./dist/signin.mjs"
      },
      "default": "./dist/signin.mjs"
    },
    "./routes/webapp": {
      "import": {
        "types": "./dist/src/routes/webapp.d.ts",
        "import": "./dist/webapp.mjs"
      },
      "default": "./dist/webapp.mjs"
    }
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false --noCheck --outDir dist && api-extractor run --local --verbose && pnpm run check:rpc-openapi",
    "check:rpc-openapi": "node ../../scripts/generate-rpc-openapi.mjs --check",
    "clean": "rimraf --glob dist .turbo node_modules/.cache node_modules/.vite* .eslintcache *.tsbuildinfo",
    "dev": "vite build --watch",
    "format": "pnpm run lint --fix && pnpm exec prettier --write ./src ./vitest.config.ts",
    "lint": "eslint --quiet ${ESLINT_CACHE_FLAG:---cache} --concurrency ${ESLINT_CONCURRENCY:-auto} --config ./eslint.config.mjs ./src ./vitest.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:debug": "tsc --noEmit --listFiles"
  },
