{
  "name": "@main/shutdown-manager",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationMap --noEmit false --noCheck --outDir dist && api-extractor run --local --verbose",
    "clean": "rimraf --glob dist .turbo node_modules/.cache node_modules/.vite* .eslintcache *.tsbuildinfo",
    "dev": "vite build --watch",
    "format": "pnpm run lint --fix && pnpm exec prettier --write ./src",
    "lint": "eslint --quiet ${ESLINT_CACHE_FLAG:---cache} --concurrency ${ESLINT_CONCURRENCY:-auto} ./src",
    "typecheck": "tsc --noEmit",
    "typecheck:debug": "tsc --noEmit --listFiles"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {}
}
